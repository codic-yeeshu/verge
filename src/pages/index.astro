---
export const prerender = false;

import { env } from 'cloudflare:workers';
import { desc, eq } from 'drizzle-orm';
import BaseLayout from '../layouts/BaseLayout.astro';
import PostCard from '../components/PostCard.astro';
import { getDb } from '../db/client';
import { posts, users } from '../db/schema';

const db = getDb(env);
const list = await db
	.select({
		id: posts.id,
		slug: posts.slug,
		title: posts.title,
		summary: posts.summary,
		publishedAt: posts.publishedAt,
		coverR2Key: posts.coverR2Key,
		tagsJson: posts.tagsJson,
		commentCount: posts.commentCount,
		bodyMd: posts.bodyMd,
		authorName: users.name,
		authorAvatar: users.avatarUrl,
	})
	.from(posts)
	.innerJoin(users, eq(users.id, posts.authorId))
	.where(eq(posts.status, 'published'))
	.orderBy(desc(posts.publishedAt))
	.limit(30);

const user = Astro.locals.user;
const geo = Astro.locals.geo;

function geoLabel(g: typeof geo): string {
	if (!g.country && !g.city) return 'localhost';
	if (g.city && g.country) return `${g.city}, ${g.country}`;
	return g.country ?? g.city ?? 'localhost';
}
const where = geoLabel(geo);

const firstName = user?.name?.trim().split(/\s+/)[0] ?? null;
const greeting = firstName ? `Welcome back, ${firstName}` : 'Latest from Verge';
---

<BaseLayout title="Verge">
	<main class="feed">
		<section class="feed-header">
			<div class="feed-header-text">
				<h1 class="feed-greeting">{greeting}</h1>
				<p class="feed-subtitle">Reading from {where}</p>
			</div>

			<form id="subscribe-form" class="feed-subscribe" aria-label="Subscribe to new posts">
				<input
					id="subscribe-email"
					class="feed-subscribe-input"
					type="email"
					name="email"
					placeholder="you@example.com"
					required
					autocomplete="email"
					aria-label="Your email address"
				/>
				<button type="submit" class="feed-subscribe-button">Subscribe</button>
				<span id="subscribe-status" class="feed-subscribe-status" aria-live="polite"></span>
			</form>
		</section>

		{
			list.length === 0 ? (
				<section class="feed-empty">
					<p class="feed-empty-mark" aria-hidden="true">—</p>
					<p class="feed-empty-line">No posts yet. Be the first.</p>
					<a href="/editor" class="feed-empty-cta">Write</a>
				</section>
			) : (
				<section class="feed-grid">
					{list.map((post) => <PostCard post={post} />)}
				</section>
			)
		}
	</main>

	<script is:inline>
		(() => {
			const form = document.getElementById('subscribe-form');
			const status = document.getElementById('subscribe-status');
			if (!form || !status) return;
			form.addEventListener('submit', async (e) => {
				e.preventDefault();
				const data = new FormData(form);
				const email = (data.get('email') ?? '').toString();
				status.textContent = 'Subscribing…';
				status.className = 'feed-subscribe-status';
				try {
					const res = await fetch('/api/subscribe', {
						method: 'POST',
						headers: { 'content-type': 'application/json' },
						body: JSON.stringify({ email }),
					});
					const body = await res.json().catch(() => ({}));
					if (res.ok) {
						status.textContent = 'Subscribed.';
						status.className = 'feed-subscribe-status feed-subscribe-status-ok';
						form.reset();
					} else {
						status.textContent =
							body.error === 'invalid_email'
								? 'Please enter a valid email.'
								: 'Something went wrong.';
						status.className = 'feed-subscribe-status feed-subscribe-status-err';
					}
				} catch {
					status.textContent = 'Network error. Try again.';
					status.className = 'feed-subscribe-status feed-subscribe-status-err';
				}
			});
		})();
	</script>
</BaseLayout>

<style>
	.feed {
		max-width: 1200px;
		margin: 0 auto;
		padding: var(--space-8) var(--space-6) var(--space-12);
	}

	.feed-header {
		display: flex;
		flex-direction: column;
		gap: var(--space-4);
		margin-bottom: var(--space-8);
		align-items: flex-start;
		justify-content: space-between;
	}

	@media (min-width: 720px) {
		.feed-header {
			flex-direction: row;
			align-items: flex-end;
			gap: var(--space-6);
		}
	}

	.feed-header-text {
		min-width: 0;
	}

	.feed-greeting {
		font-family: 'Fraunces', Georgia, serif;
		font-weight: 500;
		font-size: var(--text-2xl);
		line-height: var(--leading-snug);
		letter-spacing: -0.01em;
		color: var(--ink-1);
		margin: 0 0 6px;
		font-variation-settings: 'opsz' 36;
	}

	.feed-subtitle {
		margin: 0;
		font-size: var(--text-sm);
		color: var(--ink-3);
	}

	.feed-subscribe {
		display: flex;
		gap: var(--space-2);
		align-items: center;
		flex-wrap: wrap;
		flex-shrink: 0;
	}

	.feed-subscribe-input {
		flex: 1;
		min-width: 200px;
		height: 36px;
		background: var(--bg-surface);
		border: 1px solid var(--border-subtle);
		border-radius: var(--radius-md);
		padding: 0 var(--space-3);
		color: var(--ink-1);
		font-family: inherit;
		font-size: var(--text-sm);
		transition: border-color var(--duration-fast) var(--ease-out);
	}

	.feed-subscribe-input::placeholder {
		color: var(--ink-3);
	}

	.feed-subscribe-input:focus {
		border-color: var(--border-strong);
	}

	.feed-subscribe-button {
		height: 36px;
		padding: 0 var(--space-4);
		background: var(--accent);
		color: #fff;
		font-family: inherit;
		font-size: var(--text-sm);
		font-weight: 500;
		border: none;
		border-radius: var(--radius-md);
		cursor: pointer;
		transition: background var(--duration-fast) var(--ease-out);
	}

	.feed-subscribe-button:hover {
		background: var(--accent-hover);
	}

	.feed-subscribe-status {
		flex-basis: 100%;
		min-height: 18px;
		font-size: var(--text-xs);
		color: var(--ink-3);
	}

	.feed-subscribe-status-ok {
		color: var(--success);
	}

	.feed-subscribe-status-err {
		color: var(--danger);
	}

	.feed-empty {
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		gap: var(--space-4);
		padding: var(--space-20) var(--space-6);
		text-align: center;
	}

	.feed-empty-mark {
		font-family: 'Fraunces', Georgia, serif;
		font-size: 48px;
		font-weight: 400;
		line-height: 1;
		color: var(--border-strong);
		margin: 0;
		font-variation-settings: 'opsz' 96;
	}

	.feed-empty-line {
		margin: 0;
		font-size: var(--text-sm);
		color: var(--ink-3);
	}

	.feed-empty-cta {
		display: inline-flex;
		align-items: center;
		padding: 8px 18px;
		background: var(--accent);
		color: #fff;
		border-radius: var(--radius-md);
		font-size: var(--text-sm);
		font-weight: 500;
		transition: background var(--duration-fast) var(--ease-out);
	}

	.feed-empty-cta:hover {
		background: var(--accent-hover);
		color: #fff;
		text-decoration: none;
	}

	.feed-grid {
		display: grid;
		grid-template-columns: 1fr;
		gap: 20px;
	}

	@media (min-width: 640px) {
		.feed-grid {
			grid-template-columns: 1fr 1fr;
		}
	}

	@media (min-width: 1024px) {
		.feed-grid {
			grid-template-columns: 1fr 1fr 1fr;
		}
	}
</style>
