---
export const prerender = false;

import { env } from 'cloudflare:workers';
import { and, eq } from 'drizzle-orm';
import DiscussionRail from '../../components/DiscussionRail';
import ShareButton from '../../components/ShareButton';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getDb } from '../../db/client';
import { posts, users } from '../../db/schema';
import { logEvent } from '../../lib/log';
import { renderMarkdown } from '../../lib/markdown';
import { relativeTime } from '../../lib/time';

const slug = Astro.params.slug;
if (!slug) return new Response('Not found', { status: 404 });

const db = getDb(env);
const rows = await db
	.select({
		id: posts.id,
		slug: posts.slug,
		title: posts.title,
		bodyMd: posts.bodyMd,
		summary: posts.summary,
		tagsJson: posts.tagsJson,
		coverR2Key: posts.coverR2Key,
		publishedAt: posts.publishedAt,
		authorId: posts.authorId,
		authorName: users.name,
		authorAvatar: users.avatarUrl,
	})
	.from(posts)
	.innerJoin(users, eq(users.id, posts.authorId))
	.where(and(eq(posts.slug, slug), eq(posts.status, 'published')))
	.limit(1);

const post = rows[0];
if (!post) return new Response('Not found', { status: 404 });

const cfCountry = (Astro.request as { cf?: { country?: string } }).cf?.country ?? null;
logEvent('post_view', { postId: post.id, slug, country: cfCountry });

const bodyHtml = await renderMarkdown(post.bodyMd);

let tags: string[] = [];
if (post.tagsJson) {
	try {
		const parsed = JSON.parse(post.tagsJson);
		if (Array.isArray(parsed)) {
			tags = parsed
				.filter((t): t is string => typeof t === 'string')
				.map((t) => t.toLowerCase().trim())
				.filter(Boolean)
				.slice(0, 4);
		}
	} catch {
		tags = [];
	}
}

const wordCount = post.bodyMd.trim().split(/\s+/).filter(Boolean).length;
const readMinutes = Math.max(1, Math.round(wordCount / 200));

const timeLabel = post.publishedAt ? relativeTime(post.publishedAt) : '';
const isoDate = post.publishedAt ? new Date(post.publishedAt).toISOString() : '';
const coverSrc = post.coverR2Key ? `/api/r2/${post.coverR2Key}` : null;
const initial = (post.title.match(/\S/)?.[0] ?? '?').toUpperCase();
---

<BaseLayout title={`${post.title} · Verge`} description={post.summary ?? undefined}>
	<div id="reading-progress" class="reading-progress" aria-hidden="true"></div>

	<div class="post-hero">
		{
			coverSrc ? (
				<img
					class="post-hero-img"
					src={coverSrc}
					alt=""
					decoding="async"
					transition:name={`cover-${post.id}`}
				/>
			) : (
				<span
					class="post-hero-letter"
					aria-hidden="true"
					transition:name={`cover-${post.id}`}
				>
					{initial}
				</span>
			)
		}
		<div class="post-hero-overlay" aria-hidden="true"></div>
	</div>

	<div class="post-shell">
		<article class="post-main">
			{
				tags.length > 0 && (
					<ul class="post-tags-row">
						{tags.map((t) => <li>{t}</li>)}
					</ul>
				)
			}

			<h1 class="post-headline">{post.title}</h1>

			{post.summary && <p class="post-deck">{post.summary}</p>}

			<div class="post-byline">
				{
					post.authorAvatar ? (
						<img class="post-byline-avatar" src={post.authorAvatar} alt="" loading="lazy" />
					) : (
						<span class="post-byline-avatar post-byline-avatar-fallback" aria-hidden="true">
							{(post.authorName?.charAt(0) ?? '?').toUpperCase()}
						</span>
					)
				}
				<div class="post-byline-meta">
					<span class="post-byline-name">{post.authorName ?? 'unknown'}</span>
					{
						timeLabel && (
							<>
								<span class="post-byline-bullet" aria-hidden="true">·</span>
								<time class="post-byline-time" datetime={isoDate}>{timeLabel}</time>
							</>
						)
					}
					<span class="post-byline-bullet" aria-hidden="true">·</span>
					<span class="post-byline-readtime">{readMinutes} min read</span>
				</div>
				<div class="post-byline-actions">
					<span class="post-byline-share">
						<ShareButton slug={post.slug} client:load />
						<span class="post-byline-share-label">Share</span>
					</span>
					<a
						id="post-edit-link"
						class="post-byline-edit"
						href="/editor"
						data-author-id={post.authorId}
					>
						Edit
					</a>
				</div>
			</div>

			<div class="post-body prose" set:html={bodyHtml} />

			<section class="post-end-subscribe" aria-labelledby="post-end-subscribe-title">
				<h3 id="post-end-subscribe-title">Subscribe for new posts</h3>
				<p class="post-end-subscribe-copy">
					Get the next essay in your inbox. No spam, unsubscribe any time.
				</p>
				<form id="subscribe-form" class="subscribe-form">
					<div class="subscribe-row">
						<input
							id="subscribe-email"
							type="email"
							name="email"
							placeholder="you@example.com"
							required
							autocomplete="email"
						/>
						<button type="submit">Subscribe</button>
					</div>
					<p id="subscribe-status" class="subscribe-status" aria-live="polite"></p>
				</form>
			</section>
		</article>

		<aside class="post-rail-aside">
			<DiscussionRail postId={post.id} client:load />
		</aside>
	</div>

	<script is:inline>
		(() => {
			const bar = document.getElementById('reading-progress');
			if (!bar) return;
			let ticking = false;
			const update = () => {
				const docHeight =
					document.documentElement.scrollHeight - window.innerHeight;
				const progress = docHeight > 0 ? (window.scrollY / docHeight) * 100 : 0;
				bar.style.width = Math.min(100, Math.max(0, progress)) + '%';
				ticking = false;
			};
			update();
			window.addEventListener(
				'scroll',
				() => {
					if (!ticking) {
						requestAnimationFrame(update);
						ticking = true;
					}
				},
				{ passive: true }
			);
			window.addEventListener('resize', update, { passive: true });
		})();

		(async () => {
			try {
				const res = await fetch('/api/me');
				if (!res.ok) return;
				const { user } = await res.json();
				if (!user) return;
				const link = document.getElementById('post-edit-link');
				if (link && user.id === link.dataset.authorId) link.classList.add('visible');
			} catch {}
		})();

		(() => {
			const form = document.getElementById('subscribe-form');
			const status = document.getElementById('subscribe-status');
			if (!form || !status) return;
			form.addEventListener('submit', async (e) => {
				e.preventDefault();
				const data = new FormData(form);
				const email = (data.get('email') ?? '').toString();
				status.textContent = 'Subscribing…';
				status.className = 'subscribe-status';
				try {
					const res = await fetch('/api/subscribe', {
						method: 'POST',
						headers: { 'content-type': 'application/json' },
						body: JSON.stringify({ email }),
					});
					const body = await res.json().catch(() => ({}));
					if (res.ok) {
						status.textContent = 'Subscribed. Welcome aboard.';
						status.className = 'subscribe-status subscribe-status-ok';
						form.reset();
					} else {
						status.textContent =
							body.error === 'invalid_email'
								? 'Please enter a valid email.'
								: 'Something went wrong.';
						status.className = 'subscribe-status subscribe-status-err';
					}
				} catch {
					status.textContent = 'Network error. Try again.';
					status.className = 'subscribe-status subscribe-status-err';
				}
			});
		})();
	</script>
</BaseLayout>

<style is:global>
	/* ─── Hero ──────────────────────────────────────────── */
	.reading-progress {
		position: fixed;
		top: 64px;
		left: 0;
		width: 0;
		height: 2px;
		background: var(--accent);
		z-index: 40;
		pointer-events: none;
		transition: width 100ms linear;
	}

	@media (prefers-reduced-motion: reduce) {
		.reading-progress {
			transition: none;
		}
	}

	.post-hero {
		position: relative;
		width: 100%;
		height: 33vh;
		min-height: 220px;
		max-height: 380px;
		background-color: var(--accent-soft);
		display: flex;
		align-items: center;
		justify-content: center;
		overflow: hidden;
		margin-bottom: var(--space-10);
	}

	.post-hero-img {
		position: absolute;
		inset: 0;
		width: 100%;
		height: 100%;
		object-fit: cover;
	}

	.post-hero-overlay {
		position: absolute;
		inset: 0;
		background: linear-gradient(to bottom, transparent 60%, var(--bg-canvas) 100%);
		pointer-events: none;
	}

	.post-hero-letter {
		font-family: 'Fraunces', Georgia, serif;
		font-weight: 600;
		font-size: 200px;
		color: var(--accent-ink);
		opacity: 0.3;
		font-variation-settings: 'opsz' 144;
		line-height: 1;
	}

	@media (min-width: 1024px) {
		.post-hero {
			height: 33vh;
			max-height: 420px;
		}
	}

	/* ─── Shell layout ──────────────────────────────────── */
	.post-shell {
		max-width: 1200px;
		margin: 0 auto;
		padding: 0 var(--space-6) var(--space-16);
		display: grid;
		grid-template-columns: minmax(0, 1fr);
		gap: var(--space-12);
	}

	@media (min-width: 1024px) {
		.post-shell {
			grid-template-columns: minmax(0, 720px) 360px;
			justify-content: center;
		}
	}

	.post-main {
		max-width: 720px;
		width: 100%;
		margin: 0 auto;
	}

	.post-rail-aside {
		width: 100%;
	}

	@media (min-width: 1024px) {
		.post-rail-aside {
			position: sticky;
			top: 88px;
			align-self: start;
			max-height: calc(100vh - 100px);
		}
	}

	/* ─── Article header ────────────────────────────────── */
	.post-tags-row {
		list-style: none;
		display: flex;
		flex-wrap: wrap;
		gap: 6px;
		padding: 0;
		margin: 0;
	}

	.post-tags-row li {
		font-size: var(--text-xs);
		padding: 4px 10px;
		background: var(--bg-surface-2);
		color: var(--ink-2);
		border-radius: var(--radius-sm);
		text-transform: lowercase;
		line-height: 1.2;
	}

	.post-headline {
		font-family: 'Fraunces', Georgia, serif;
		font-weight: 500;
		font-size: var(--text-4xl);
		line-height: var(--leading-tight);
		letter-spacing: -0.02em;
		color: var(--ink-1);
		margin: var(--space-3) 0 0;
		font-variation-settings: 'opsz' 96;
	}

	.post-deck {
		font-family: 'Source Serif 4', Georgia, serif;
		font-style: italic;
		font-size: 22px;
		line-height: var(--leading-snug);
		color: var(--ink-2);
		margin: var(--space-4) 0 0;
		font-variation-settings: 'opsz' 28;
	}

	/* ─── Byline strip ──────────────────────────────────── */
	.post-byline {
		display: flex;
		align-items: center;
		gap: 12px;
		flex-wrap: wrap;
		margin: var(--space-8) 0 var(--space-10);
		padding: var(--space-4) 0;
		border-top: 1px solid var(--border-subtle);
		border-bottom: 1px solid var(--border-subtle);
	}

	.post-byline-avatar {
		width: 40px;
		height: 40px;
		border-radius: var(--radius-full);
		object-fit: cover;
		flex-shrink: 0;
	}

	.post-byline-avatar-fallback {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		background: var(--accent-soft);
		color: var(--accent-ink);
		font-family: 'Fraunces', Georgia, serif;
		font-weight: 600;
		font-size: 16px;
	}

	.post-byline-meta {
		display: flex;
		align-items: center;
		gap: 8px;
		flex: 1;
		min-width: 0;
		font-size: var(--text-sm);
		color: var(--ink-3);
		flex-wrap: wrap;
	}

	.post-byline-name {
		color: var(--ink-1);
		font-weight: 500;
	}

	.post-byline-bullet {
		color: var(--ink-4);
	}

	.post-byline-actions {
		display: flex;
		align-items: center;
		gap: var(--space-2);
		margin-left: auto;
	}

	.post-byline-share {
		display: inline-flex;
		align-items: center;
		gap: 6px;
		padding: 6px 10px 6px 6px;
		border-radius: var(--radius-md);
		color: var(--ink-2);
		font-size: var(--text-sm);
		transition: background var(--duration-fast) var(--ease-out);
	}

	.post-byline-share:hover {
		background: var(--bg-surface-2);
		color: var(--ink-1);
	}

	.post-byline-share .post-card-action {
		pointer-events: auto;
	}

	.post-byline-edit {
		display: none;
		padding: 6px 12px;
		border-radius: var(--radius-md);
		color: var(--ink-2);
		font-size: var(--text-sm);
		font-weight: 500;
		text-decoration: none;
		transition: background var(--duration-fast) var(--ease-out);
	}

	.post-byline-edit.visible {
		display: inline-flex;
	}

	.post-byline-edit:hover {
		background: var(--bg-surface-2);
		color: var(--ink-1);
		text-decoration: none;
	}

	/* ─── Article body (prose) ──────────────────────────── */
	.post-body.prose {
		max-width: none;
		font-family: 'Source Serif 4', Georgia, serif;
		font-size: 19px;
		line-height: var(--leading-relaxed);
		color: var(--ink-1);
		font-variation-settings: 'opsz' 28;
	}

	.post-body.prose > * + * {
		margin-top: 0;
	}

	.post-body.prose p {
		margin: 0 0 var(--space-5);
	}

	.post-body.prose h2 {
		font-family: 'Fraunces', Georgia, serif;
		font-weight: 500;
		font-size: 28px;
		line-height: var(--leading-snug);
		color: var(--ink-1);
		margin: var(--space-12) 0 var(--space-4);
		font-variation-settings: 'opsz' 36;
	}

	.post-body.prose h3 {
		font-family: 'Fraunces', Georgia, serif;
		font-weight: 500;
		font-size: 22px;
		line-height: var(--leading-snug);
		color: var(--ink-1);
		margin: var(--space-8) 0 var(--space-3);
		font-variation-settings: 'opsz' 28;
	}

	.post-body.prose blockquote {
		border-left: 3px solid var(--accent);
		padding: 0 0 0 var(--space-5);
		margin: var(--space-6) 0;
		font-style: italic;
		color: var(--ink-2);
	}

	.post-body.prose ul,
	.post-body.prose ol {
		margin: 0 0 var(--space-5);
		padding-left: 1.4em;
	}

	.post-body.prose li + li {
		margin-top: var(--space-2);
	}

	.post-body.prose code {
		font-family: 'JetBrains Mono', ui-monospace, monospace;
		font-size: 0.92em;
		background: var(--bg-surface-2);
		color: var(--ink-1);
		padding: 2px 6px;
		border-radius: 4px;
		border: none;
	}

	.post-body.prose pre {
		font-family: 'JetBrains Mono', ui-monospace, monospace;
		font-size: 14px;
		background: var(--bg-surface-2);
		color: var(--ink-1);
		padding: var(--space-4);
		border-radius: var(--radius-md);
		border: 1px solid var(--border-subtle);
		overflow-x: auto;
		margin: var(--space-6) 0;
		line-height: 1.55;
	}

	.post-body.prose pre code {
		background: none;
		padding: 0;
		font-size: inherit;
	}

	.post-body.prose hr {
		border: none;
		height: 1px;
		background: var(--border-subtle);
		margin: var(--space-12) 0;
	}

	.post-body.prose a {
		color: var(--accent);
		text-decoration: underline;
		text-decoration-thickness: 1px;
		text-underline-offset: 3px;
	}

	.post-body.prose a:hover {
		color: var(--accent-hover);
	}

	.post-body.prose figure {
		margin: var(--space-8) 0;
	}

	.post-body.prose figure img {
		width: 100%;
		height: auto;
		border-radius: var(--radius-md);
		display: block;
	}

	.post-body.prose figcaption {
		font-family: 'Inter', sans-serif;
		font-size: 14px;
		font-style: italic;
		color: var(--ink-3);
		text-align: center;
		margin-top: var(--space-2);
	}

	.post-body.prose img {
		max-width: 100%;
		height: auto;
		border-radius: var(--radius-md);
		margin: var(--space-8) 0;
	}

	/* ─── End-of-post subscribe (mobile only) ───────────── */
	.post-end-subscribe {
		margin-top: var(--space-12);
		padding: var(--space-6);
		border: 1px solid var(--border-subtle);
		border-radius: var(--radius-lg);
		background: var(--bg-surface);
	}

	.post-end-subscribe h3 {
		margin: 0 0 var(--space-2);
		font-family: 'Fraunces', Georgia, serif;
		font-weight: 500;
		font-size: var(--text-xl);
		color: var(--ink-1);
		font-variation-settings: 'opsz' 28;
	}

	.post-end-subscribe-copy {
		margin: 0 0 var(--space-4);
		color: var(--ink-3);
		font-size: var(--text-sm);
	}

	@media (min-width: 1024px) {
		.post-end-subscribe {
			display: none;
		}
	}

	/* ─── Discussion rail ──────────────────────────────── */
	.rail {
		display: flex;
		flex-direction: column;
		background: var(--bg-surface);
		border: 1px solid var(--border-subtle);
		border-radius: var(--radius-lg);
		padding: var(--space-5);
		min-height: 320px;
	}

	@media (min-width: 1024px) {
		.rail {
			max-height: calc(100vh - 100px);
		}
	}

	.rail-head {
		display: flex;
		justify-content: space-between;
		align-items: center;
		gap: var(--space-3);
		padding-bottom: var(--space-4);
		border-bottom: 1px solid var(--border-subtle);
	}

	.rail-title {
		font-family: 'Fraunces', Georgia, serif;
		font-weight: 500;
		font-size: 18px;
		color: var(--ink-1);
		margin: 0;
		font-variation-settings: 'opsz' 24;
	}

	.rail-presence {
		display: inline-flex;
		align-items: center;
		gap: 6px;
		font-size: var(--text-xs);
		color: var(--ink-3);
	}

	.rail-dot {
		display: inline-block;
		width: 6px;
		height: 6px;
		border-radius: 50%;
		background: var(--ink-4);
		flex-shrink: 0;
	}

	.rail-dot.is-live {
		background: var(--success);
		animation: railDotPulse 2s ease-in-out infinite;
	}

	@keyframes railDotPulse {
		0%, 100% { opacity: 0.55; }
		50% { opacity: 1; }
	}

	.rail-list {
		display: flex;
		flex-direction: column;
		gap: var(--space-4);
		padding: var(--space-4) 0;
		overflow-y: auto;
		flex: 1;
		min-height: 0;
	}

	.rail-empty {
		margin: 0;
		font-size: var(--text-sm);
		color: var(--ink-3);
		font-style: italic;
	}

	.rail-comments {
		list-style: none;
		display: flex;
		flex-direction: column;
		gap: var(--space-4);
		padding: 0;
		margin: 0;
	}

	.rail-comment {
		display: flex;
		align-items: flex-start;
		gap: var(--space-3);
		animation: railFadeSlideIn 240ms var(--ease-out);
	}

	@keyframes railFadeSlideIn {
		0% { opacity: 0; transform: translateY(8px); }
		100% { opacity: 1; transform: translateY(0); }
	}

	.rail-comment-avatar {
		width: 28px;
		height: 28px;
		border-radius: 50%;
		background: var(--accent-soft);
		color: var(--accent-ink);
		font-family: 'Fraunces', Georgia, serif;
		font-weight: 600;
		font-size: 12px;
		display: inline-flex;
		align-items: center;
		justify-content: center;
		flex-shrink: 0;
	}

	.rail-comment-bubble {
		flex: 1;
		min-width: 0;
	}

	.rail-comment-meta {
		display: flex;
		align-items: baseline;
		gap: var(--space-2);
		font-family: 'Inter', sans-serif;
	}

	.rail-comment-meta strong {
		font-size: 13px;
		font-weight: 500;
		color: var(--ink-1);
	}

	.rail-comment-time {
		font-size: 11px;
		color: var(--ink-3);
	}

	.rail-comment-text {
		font-family: 'Source Serif 4', Georgia, serif;
		font-size: 14px;
		line-height: var(--leading-normal);
		color: var(--ink-2);
		margin-top: 2px;
		white-space: pre-wrap;
		word-break: break-word;
	}

	.rail-typing {
		display: flex;
		align-items: center;
		gap: 4px;
		font-size: 12px;
		font-style: italic;
		color: var(--ink-3);
	}

	.rail-typing-dots {
		display: inline-flex;
