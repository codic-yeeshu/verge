---
export const prerender = false;

import Editor from '../components/Editor';
import BaseLayout from '../layouts/BaseLayout.astro';

const user = Astro.locals.user;
if (!user) {
	return Astro.redirect('/api/auth/github');
}
---

<BaseLayout title="Write a post · Verge">
	<header class="site-header">
		<a href="/" class="brand">Verge</a>
		<nav>
			<span style="color: var(--muted); font-size: 14px;">Hi, {user.name}</span>
			<form action="/api/auth/logout" method="post" style="display: inline; margin: 0;">
				<button type="submit" class="signout">Sign out</button>
			</form>
		</nav>
	</header>
	<main>
		<Editor client:only="react" />
	</main>
</BaseLayout>
