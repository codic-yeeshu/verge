---
export const prerender = false;

import Editor from '../components/Editor';
import BaseLayout from '../layouts/BaseLayout.astro';

const user = Astro.locals.user;
if (!user) {
	return Astro.redirect('/api/auth/github');
}
---

<BaseLayout title="Write a post · Verge">
	<main class="editor-page">
		<Editor client:only="react" />
	</main>
</BaseLayout>

<style is:global>
	.editor-page {
		max-width: 800px;
		margin: 0 auto;
		padding: var(--space-8) var(--space-6) var(--space-20);
	}

	.editor-shell {
		display: flex;
		flex-direction: column;
		gap: var(--space-6);
	}

	/* ── Title ──────────────────────────────────────── */
	.editor-title {
		width: 100%;
		background: transparent;
		border: none;
		border-bottom: 1px solid var(--border-subtle);
		font-family: 'Fraunces', Georgia, serif;
		font-weight: 500;
		font-size: var(--text-3xl);
		line-height: 1.2;
		color: var(--ink-1);
		padding: var(--space-3) 0;
		outline: none;
		letter-spacing: -0.01em;
		font-variation-settings: 'opsz' 96;
		transition: border-color var(--duration-fast) var(--ease-out);
	}

	.editor-title::placeholder {
		color: var(--ink-4);
		font-weight: 400;
	}

	.editor-title:focus {
		border-bottom-color: var(--accent);
	}

	.editor-title:disabled {
		opacity: 0.7;
		cursor: not-allowed;
	}

	/* ── Cover upload zone ──────────────────────────── */
	.editor-cover {
		display: block;
	}

	.cover-zone {
		display: flex;
		align-items: center;
		justify-content: center;
		gap: 10px;
		border: 2px dashed var(--border-subtle);
		border-radius: var(--radius-lg);
		padding: var(--space-8);
		color: var(--ink-3);
		font-size: var(--text-sm);
		background: transparent;
		cursor: pointer;
		transition:
			border-color var(--duration-fast) var(--ease-out),
			background var(--duration-fast) var(--ease-out),
			color var(--duration-fast) var(--ease-out);
	}

	.cover-zone:hover {
		border-color: var(--accent);
		background: var(--accent-soft);
		color: var(--accent-ink);
	}

	.cover-zone.is-uploading {
		border-style: solid;
		border-color: var(--border-strong);
		color: var(--ink-2);
		cursor: wait;
	}

	.cover-loaded {
		position: relative;
		border-radius: var(--radius-lg);
		overflow: hidden;
		background: var(--bg-surface-2);
	}

	.cover-loaded img {
		width: 100%;
		height: auto;
		max-height: 360px;
		object-fit: cover;
		display: block;
	}

	.cover-replace {
		position: absolute;
		top: var(--space-3);
		right: var(--space-3);
		display: inline-flex;
		align-items: center;
		gap: 4px;
		padding: 6px 10px;
		background: rgba(20, 17, 13, 0.7);
		color: #fff;
		font-size: var(--text-xs);
		font-weight: 500;
		border-radius: var(--radius-md);
		cursor: pointer;
		backdrop-filter: blur(8px);
		transition: background var(--duration-fast) var(--ease-out);
	}

	.cover-replace:hover {
		background: rgba(20, 17, 13, 0.85);
	}

	/* ── Status pill (fixed top-right under nav) ────── */
	.editor-status {
		position: fixed;
		top: 80px;
		right: var(--space-6);
		z-index: 30;
		display: inline-flex;
		align-items: center;
		gap: 6px;
		padding: 4px 12px;
		border-radius: var(--radius-full);
		font-size: var(--text-xs);
		font-weight: 500;
		font-family: 'Inter', sans-serif;
		text-decoration: none;
		line-height: 1.2;
		transition:
			background var(--duration-base) var(--ease-out),
			color var(--duration-base) var(--ease-out);
	}

	.editor-status-draft {
		background: var(--bg-surface-2);
		color: var(--ink-2);
	}

	.editor-status-processing {
		background: var(--accent-soft);
		color: var(--accent-ink);
	}

	.editor-status-published {
		background: color-mix(in srgb, var(--success) 15%, transparent);
		color: var(--success);
		text-decoration: none;
	}

	.editor-status-published:hover {
		background: color-mix(in srgb, var(--success) 22%, transparent);
		text-decoration: none;
		color: var(--success);
	}

	.editor-status-error {
		background: color-mix(in srgb, var(--danger) 12%, transparent);
		color: var(--danger);
		cursor: help;
	}

	.spinner {
		animation: editor-spin 0.9s linear infinite;
	}

	@keyframes editor-spin {
		from {
			transform: rotate(0deg);
		}
		to {
			transform: rotate(360deg);
		}
	}

	/* ── Floating publish button ────────────────────── */
	.editor-publish {
		position: fixed;
		bottom: var(--space-6);
		right: var(--space-6);
		z-index: 30;
		background: var(--accent);
		color: #fff;
		font-family: 'Fraunces', Georgia, serif;
		font-weight: 500;
		font-size: 16px;
		padding: 12px 24px;
		border-radius: var(--radius-full);
		border: none;
		cursor: pointer;
		box-shadow: var(--shadow-lg);
		font-variation-settings: 'opsz' 24;
		transition:
			background var(--duration-fast) var(--ease-out),
			transform var(--duration-fast) var(--ease-out),
			box-shadow var(--duration-fast) var(--ease-out);
	}

	.editor-publish:hover:not(:disabled) {
		background: var(--accent-hover);
		transform: translateY(-1px);
	}

	.editor-publish:disabled {
		background: var(--bg-surface-2);
		color: var(--ink-4);
		cursor: not-allowed;
		box-shadow: var(--shadow-sm);
	}

	.editor-error {
		margin: 0;
		color: var(--danger);
		font-size: var(--text-sm);
	}

	/* ── @uiw/react-md-editor overrides ─────────────── */
	.editor-md {
		--md-editor-bg: var(--bg-surface);
		--md-editor-border: var(--border-subtle);
	}

	.editor-md .w-md-editor {
		background: var(--bg-surface);
		border: 1px solid var(--border-subtle);
		border-radius: var(--radius-md);
		box-shadow: none;
		color: var(--ink-1);
	}

	.editor-md .w-md-editor-toolbar {
		background: var(--bg-surface-2);
		border-bottom: 1px solid var(--border-subtle);
		border-top-left-radius: var(--radius-md);
		border-top-right-radius: var(--radius-md);
	}

	.editor-md .w-md-editor-toolbar button {
		color: var(--ink-2);
	}

	.editor-md .w-md-editor-toolbar button:hover {
		color: var(--ink-1);
		background: var(--bg-surface);
	}

	.editor-md .w-md-editor-toolbar svg {
		fill: currentColor;
	}

	.editor-md .w-md-editor-toolbar-divider {
		background: var(--border-subtle);
	}

	.editor-md .w-md-editor-content {
		background: var(--bg-surface);
	}

	/* The textarea sits transparent on top of <pre> and the caret is positioned
	   by the textarea's font metrics while the visible text is drawn by <pre>.
	   Any inherited difference between the two layers (letter-spacing,
	   font-feature-settings, variation axis, tab-size, weight) compounds per
	   character and shows up as caret drift. Lock every glyph-affecting
	   property to identical values on both layers. */
	.editor-md .w-md-editor-text-input,
	.editor-md .w-md-editor-text-pre,
	.editor-md .w-md-editor-text > .w-md-editor-text-pre,
	.editor-md .w-md-editor-text-pre code {
		font-family: 'Source Serif 4', Georgia, serif !important;
		font-size: 17px !important;
		line-height: 1.7 !important;
		font-weight: 400 !important;
		font-style: normal !important;
		font-variation-settings: 'opsz' 28 !important;
		font-feature-settings: normal !important;
		letter-spacing: 0 !important;
		word-spacing: 0 !important;
		tab-size: 4 !important;
		text-transform: none !important;
		font-kerning: none !important;
		-webkit-font-smoothing: auto !important;
	}

	/* Visible-text color goes on the pre layer only — never on the textarea. */
	.editor-md .w-md-editor-text-pre,
	.editor-md .w-md-editor-text > .w-md-editor-text-pre,
	.editor-md .w-md-editor-text-pre code {
		color: var(--ink-1) !important;
	}

	.editor-md .w-md-editor-text {
		background: var(--bg-surface) !important;
	}

	/* Textarea stays transparent text — only its caret is visible. */
	.editor-md .w-md-editor-text-input {
		caret-color: var(--ink-1) !important;
	}

	.editor-md .w-md-editor-preview {
		background: var(--bg-surface);
		color: var(--ink-1);
		padding: var(--space-5) !important;
	}

	.editor-md .w-md-editor-preview h1,
	.editor-md .w-md-editor-preview h2,
	.editor-md .w-md-editor-preview h3,
	.editor-md .w-md-editor-preview h4 {
		font-family: 'Fraunces', Georgia, serif !important;
		font-weight: 500 !important;
		color: var(--ink-1) !important;
	}

	.editor-md .w-md-editor-preview p,
	.editor-md .w-md-editor-preview li {
		font-family: 'Source Serif 4', Georgia, serif !important;
		font-size: 16px !important;
		line-height: 1.7 !important;
		color: var(--ink-1) !important;
	}

	.editor-md .w-md-editor-preview a {
		color: var(--accent) !important;
	}

	.editor-md .w-md-editor-preview blockquote {
		border-left: 3px solid var(--accent) !important;
		color: var(--ink-2) !important;
		background: transparent !important;
	}

	.editor-md .w-md-editor-preview code,
	.editor-md .w-md-editor-preview pre,
	.editor-md .w-md-editor-preview pre code {
		font-family: 'JetBrains Mono', ui-monospace, SFMono-Regular, Menlo, monospace !important;
		background: var(--bg-surface-2) !important;
		color: var(--ink-1) !important;
		border-radius: var(--radius-sm);
	}

	.editor-md .w-md-editor-preview pre {
		padding: var(--space-3) var(--space-4) !important;
		border-radius: var(--radius-md) !important;
		border: 1px solid var(--border-subtle) !important;
	}

	.editor-md .w-md-editor-bar {
		background: var(--border-subtle);
	}
</style>
