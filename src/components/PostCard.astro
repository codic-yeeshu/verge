---
import ShareButton from './ShareButton';

interface Post {
	id: string;
	slug: string;
	title: string;
	summary: string | null;
	publishedAt: number | null;
	coverR2Key: string | null;
	tagsJson: string | null;
	commentCount: number;
	bodyMd: string;
	authorName: string | null;
	authorAvatar: string | null;
}

interface Props {
	post: Post;
}

const { post } = Astro.props;

let tags: string[] = [];
if (post.tagsJson) {
	try {
		const parsed = JSON.parse(post.tagsJson);
		if (Array.isArray(parsed)) {
			tags = parsed
				.filter((t): t is string => typeof t === 'string')
				.map((t) => t.toLowerCase().trim())
				.filter(Boolean)
				.slice(0, 3);
		}
	} catch {
		tags = [];
	}
}

const wordCount = post.bodyMd.trim().split(/\s+/).filter(Boolean).length;
const readMinutes = Math.max(1, Math.round(wordCount / 200));

function relativeTime(ts: number): string {
	const diffMs = Date.now() - ts;
	const seconds = Math.max(0, Math.floor(diffMs / 1000));
	if (seconds < 45) return 'just now';
	const rtf = new Intl.RelativeTimeFormat('en', { numeric: 'auto' });
	const minutes = Math.floor(seconds / 60);
	if (minutes < 60) return rtf.format(-minutes, 'minute');
	const hours = Math.floor(minutes / 60);
	if (hours < 24) return rtf.format(-hours, 'hour');
	const days = Math.floor(hours / 24);
	if (days < 30) return rtf.format(-days, 'day');
	const months = Math.floor(days / 30);
	if (months < 12) return rtf.format(-months, 'month');
	return rtf.format(-Math.floor(months / 12), 'year');
}

const timeLabel = post.publishedAt ? relativeTime(post.publishedAt) : '';
const initial = (post.title.match(/\S/)?.[0] ?? '?').toUpperCase();
// Direct R2 proxy. `/cdn-cgi/image/...` resizing is a custom-domain + paid
// Image Resizing feature; revisit once that's wired up.
const coverSrc = post.coverR2Key ? `/api/r2/${post.coverR2Key}` : null;
---

<a class="post-card-v2" href={`/post/${post.slug}`}>
	{
		coverSrc ? (
			<div class="post-card-cover">
				<img src={coverSrc} alt="" loading="lazy" />
			</div>
		) : (
			<div class="post-card-cover post-card-cover-placeholder" aria-hidden="true">
				<span class="post-card-initial">{initial}</span>
			</div>
		)
	}

	<div class="post-card-body">
		{
			tags.length > 0 && (
				<div class="post-card-tags">
					{tags.map((t) => <span class="post-card-tag">{t}</span>)}
				</div>
			)
		}
		<h3 class="post-card-title">{post.title}</h3>
		{post.summary && <p class="post-card-summary">{post.summary}</p>}

		<div class="post-card-footer">
			<div class="post-card-meta">
				{
					post.authorAvatar ? (
						<img class="post-card-avatar" src={post.authorAvatar} alt="" loading="lazy" />
					) : (
						<span class="post-card-avatar post-card-avatar-fallback" aria-hidden="true">
							{(post.authorName?.charAt(0) ?? '?').toUpperCase()}
						</span>
					)
				}
				<span class="post-card-author">{post.authorName ?? 'unknown'}</span>
				{
					timeLabel && (
						<>
							<span class="post-card-bullet" aria-hidden="true">·</span>
							<span class="post-card-time">{timeLabel}</span>
						</>
					)
				}
				<span class="post-card-bullet" aria-hidden="true">·</span>
				<span class="post-card-readtime">{readMinutes} min read</span>
			</div>

			<div class="post-card-actions">
				<span class="post-card-action post-card-action-static" aria-label={`${post.commentCount} comments`}>
					<svg
						width="16"
						height="16"
						viewBox="0 0 24 24"
						fill="none"
						stroke="currentColor"
						stroke-width="1.75"
						stroke-linecap="round"
						stroke-linejoin="round"
						aria-hidden="true"
					>
						<path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path>
					</svg>
					<span class="post-card-count">{post.commentCount}</span>
				</span>
				<ShareButton slug={post.slug} client:load />
			</div>
		</div>
	</div>
</a>

<style is:global>
	.post-card-v2 {
		display: flex;
		flex-direction: column;
		background: var(--bg-surface);
		border: 1px solid var(--border-subtle);
		border-radius: var(--radius-lg);
		overflow: hidden;
		text-decoration: none;
		color: inherit;
		transition:
			transform var(--duration-base) var(--ease-out),
			box-shadow var(--duration-base) var(--ease-out),
			border-color var(--duration-base) var(--ease-out);
	}

	.post-card-v2:hover {
		transform: translateY(-2px);
		box-shadow: var(--shadow-md);
		border-color: var(--border-strong);
		text-decoration: none;
		color: inherit;
	}

	.post-card-cover {
		aspect-ratio: 16 / 9;
		background: var(--bg-surface-2);
		overflow: hidden;
	}

	.post-card-cover img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		display: block;
	}

	.post-card-cover-placeholder {
		background: var(--accent-soft);
		display: flex;
		align-items: center;
		justify-content: center;
	}

	.post-card-initial {
		font-family: 'Fraunces', Georgia, serif;
		font-weight: 600;
		font-size: 64px;
		line-height: 1;
		color: var(--accent-ink);
		font-variation-settings: 'opsz' 96;
	}

	.post-card-body {
		display: flex;
		flex-direction: column;
		gap: var(--space-3);
		padding: var(--space-5);
		flex: 1;
	}

	.post-card-tags {
		display: flex;
		flex-wrap: wrap;
		gap: 6px;
	}

	.post-card-tag {
		font-size: var(--text-xs);
		padding: 4px 10px;
		background: var(--bg-surface-2);
		color: var(--ink-2);
		border-radius: var(--radius-sm);
		text-transform: lowercase;
		line-height: 1.2;
	}

	.post-card-title {
		font-family: 'Fraunces', Georgia, serif;
		font-weight: 500;
		font-size: var(--text-lg);
		line-height: var(--leading-snug);
		color: var(--ink-1);
		margin: 0;
		display: -webkit-box;
		-webkit-line-clamp: 2;
		-webkit-box-orient: vertical;
		overflow: hidden;
		font-variation-settings: 'opsz' 24;
	}

	.post-card-summary {
		font-family: inherit;
		font-size: var(--text-sm);
		line-height: var(--leading-normal);
		color: var(--ink-2);
		margin: 0;
		display: -webkit-box;
		-webkit-line-clamp: 3;
		-webkit-box-orient: vertical;
		overflow: hidden;
	}

	.post-card-footer {
		display: flex;
		justify-content: space-between;
		align-items: center;
		gap: var(--space-3);
		border-top: 1px solid var(--border-subtle);
		padding-top: var(--space-3);
		margin-top: auto;
	}

	.post-card-meta {
		display: flex;
		align-items: center;
		gap: 6px;
		font-size: var(--text-xs);
		color: var(--ink-3);
		min-width: 0;
		overflow: hidden;
	}

	.post-card-avatar {
		width: 20px;
		height: 20px;
		border-radius: var(--radius-full);
		flex-shrink: 0;
		object-fit: cover;
	}

	.post-card-avatar-fallback {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		background: var(--accent-soft);
		color: var(--accent-ink);
		font-family: 'Fraunces', Georgia, serif;
		font-size: 12px;
		font-weight: 600;
	}

	.post-card-author {
		color: var(--ink-2);
		font-weight: 500;
		white-space: nowrap;
		overflow: hidden;
		text-overflow: ellipsis;
		min-width: 0;
	}

	.post-card-bullet {
		color: var(--ink-4);
	}

	.post-card-time,
	.post-card-readtime {
		white-space: nowrap;
	}

	.post-card-actions {
		display: flex;
		gap: var(--space-1);
		flex-shrink: 0;
	}

	.post-card-action {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		gap: 4px;
		min-width: 28px;
		height: 28px;
		padding: 0 6px;
		border-radius: var(--radius-sm);
		color: var(--ink-3);
		background: none;
		border: none;
		cursor: pointer;
		font-size: var(--text-xs);
		font-weight: 500;
		transition:
			background var(--duration-fast) var(--ease-out),
			color var(--duration-fast) var(--ease-out);
	}

	.post-card-action:hover {
		background: var(--bg-surface-2);
		color: var(--ink-1);
	}

	.post-card-action-static {
		pointer-events: none;
	}

	.post-card-count {
		font-variant-numeric: tabular-nums;
	}

	.post-card-action.is-copied {
		color: var(--success);
	}
</style>
